{
  "name": "agency-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:turbo": "next dev --turbo -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "prod": "npm run build && npm run start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "prepare": "husky",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "framer-motion": "^11.0.23",
    "next": "14.2.5",
    "next-seo": "^6.5.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.9",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "husky": "^9.1.6",
    "kiro-cli": "^0.0.1",
    "lint-staged": "^15.2.8",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.5.4",
    "vitest": "^2.1.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
