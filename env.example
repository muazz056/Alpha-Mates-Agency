# Agency Portfolio - Environment Variables
# Copy this file to .env.local and fill in your values

# ======================
# OPTIONAL INTEGRATIONS
# ======================

# Google Analytics (optional)
# Get your ID from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=

# Form Handling Service (optional)
# Use Formspree, Getform, or custom endpoint
NEXT_PUBLIC_FORM_ENDPOINT=

# ======================
# AI FEATURES (optional)
# ======================

# OpenAI API Key (for AI demo features)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ======================
# EMAIL & NOTIFICATIONS
# ======================

# Contact form email notifications (optional)
SENDGRID_API_KEY=
CONTACT_EMAIL=hello@example.com

# ======================
# DEPLOYMENT
# ======================

# Production URL (for SEO & OG images)
NEXT_PUBLIC_SITE_URL=https://youragency.com

# ======================
# NOTES
# ======================

# 1. Never commit .env.local to git
# 2. All NEXT_PUBLIC_* variables are exposed to the browser
# 3. Server-only variables don't need NEXT_PUBLIC_ prefix
# 4. Restart dev server after changing env variables

